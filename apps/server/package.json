{
  "name": "@voxcomposer/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vox Composer local backend — project storage, audio transcoding, and live-preview relay.",
  "license": "MIT",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@voxcomposer/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
