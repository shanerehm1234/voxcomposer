{
  "name": "voxcomposer",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based PWA for designing and playing back synchronized animatronic shows for haunted attractions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rehmlights/voxcomposer.git"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @voxcomposer/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
