# Vox Composer environment configuration.
# Copy to .env and fill in as needed. Every value is optional — with none set,
# the app runs as a static, single-user, fully-local editor.
#
# NOTE: the backend (apps/server) is not built yet; these document the intended
# configuration so it's stable from day one. The web app needs none of these.

# --- Server ---------------------------------------------------------------
# Port the API server listens on.
PORT=8080

# --- Database (project metadata only — never media) -----------------------
# Postgres connection string. If unset, the server runs without persistence.
# DATABASE_URL=postgresql://vox:vox@localhost:5432/voxcomposer

# --- Object storage (S3-compatible; audio + .vox JSON) --------------------
# If unset, the server falls back to local-disk storage (self-host only).
# Works with AWS S3, DigitalOcean Spaces, Cloudflare R2, or local MinIO.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=voxcomposer
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true       # required for MinIO

# --- Auth (Clerk) ---------------------------------------------------------
# If unset, the app runs in single-user mode with no login.
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# --- Media transcoding ----------------------------------------------------
# Path to the ffmpeg binary used to transcode imported MP3/OGG/M4A to the WAV
# spec each remote requires, at sync time. Defaults to "ffmpeg" on PATH.
# FFMPEG_PATH=ffmpeg

# --- Vox Master -----------------------------------------------------------
# Default local IP of the Vox Master station (override in Settings UI).
# VOX_MASTER_IP=192.168.4.1
